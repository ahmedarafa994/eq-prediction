experiment_name: idsp-eq-v6-fix
seed: 42
data:
  num_bands: 3
  sample_rate: 44100
  audio_duration: 1.5
  n_fft: 4096
  hop_length: 512
  n_mels: 256
  filterbank_type: log
  gain_bounds:
  - -24.0
  - 24.0
  freq_bounds:
  - 20.0
  - 20000.0
  q_bounds:
  - 0.1
  - 10.0
  filter_types:
  - peaking
  - lowshelf
  - highshelf
  - highpass
  - lowpass
  type_weights:
  - 0.5
  - 0.15
  - 0.15
  - 0.1
  - 0.1
  train_split: 0.8
  val_split: 0.1
  test_split: 0.1
  batch_size: 2048
  num_workers: 4
  dataset_size: 50000
  musdb_enabled: true
  musdb_size: 50000
  musdb_root: /teamspace/studios/this_studio/insight/data/musdb18_hq
  use_specaugment: true
model:
  encoder:
    type: tcn
    n_mels: 256
    embedding_dim: 256
    channels: 256
    num_blocks: 8
    num_stacks: 3
    kernel_size: 5
  num_bands: 3
  learning_rate: 0.0001
  weight_decay: 0.0001
  use_full_spectrum: false
loss:
  lambda_param: 1.0
  lambda_type: 2.0
  lambda_spectral: 0.0
  lambda_hmag: 0.5
  lambda_activity: 0.0
  lambda_spread: 0.05
  lambda_coverage: 0.02
  lambda_freq_anchor: 1.5
  lambda_attn_entropy: 0.05
  lambda_freq_match: 1.0
  lambda_q_match: 0.5
  lambda_freq_internal: 1.5
  lambda_recon: 0.1
trainer:
  max_epochs: 165
  accelerator: gpu
  devices: 1
  precision: bf16-mixed
  log_every_n_steps: 10
  check_val_every_n_epoch: 3
  accumulate_grad_batches: 2
  fast_dev_run: false
  num_sanity_val_steps: 1
  cudnn_benchmark: true
  cudnn_deterministic: false
  torch_compile: false
  early_stopping_patience: 25
  lr_schedule: cosine_warm_restarts
  lr_patience: 5
  lr_factor: 0.5
  lr_min: 1.0e-06
  ema_decay: 0.999
  warmup_fraction: 0.05
