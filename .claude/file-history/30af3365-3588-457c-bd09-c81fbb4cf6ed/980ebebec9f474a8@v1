        if batch_id is None:
            batch_id = timestamp.isoformat()
        
        report = {
            'batch_id': batch_id,
            'timestamp': timestamp.isoformat(),
            'total_rows': len(data),
            'failed_rows': 0,
            'failure_rate': 0.0,
