"""
Generate a 200K precomputed MUSDB18 EQ dataset.

Creates data/dataset_musdb_200k.pt compatible with the training pipeline.
Each sample: wet_mel (log-mel spectrogram), gain, freq, q, filter_type tensors.
Uses diverse random EQ configurations across 5 filter types.
"""

import sys
import time
import math
import random
import numpy as np
import torch
import torchaudio
from pathlib import Path

sys.path.append(str(Path(__file__).parent))

MUSDB_ROOT = "/teamspace/lightning_storage/SNAP_DATA_SET/musdb18_hq"
SR = 44100
N_FFT = 2048
HOP = N_FFT // 4  # 512
N_MELS = 128
DURATION = 3.0
NUM_SAMPLES = int(DURATION * SR)
N_BANDS = 5
SIZE = 200_000
BATCH_SAVE = 10_000  # Save in chunks to manage memory

FILTER_PEAKING = 0
FILTER_LOWSHELF = 1
FILTER_HIGHSHELF = 2
FILTER_HIGHPASS = 3
FILTER_LOWPASS = 4
FILTER_NAMES = ["peaking", "lowshelf", "highshelf", "highpass", "lowpass"]
TYPE_WEIGHTS = [0.5, 0.15, 0.15, 0.1, 0.1]


def load_musdb_audio():
    """Load all MUSDB18 mixture tracks into memory."""
    audio_segments = []
    musdb_root = Path(MUSDB_ROOT)
    for subset in ["train", "test"]:
        subset_dir = musdb_root / subset
        if not subset_dir.exists():
            continue
        for song_dir in sorted(subset_dir.iterdir()):
            if not song_dir.is_dir():
                continue
            wav_path = song_dir / "mixture.wav"
            if not wav_path.exists():
                continue
            wf, sr = torchaudio.load(str(wav_path))
            if sr != SR:
                wf = torchaudio.functional.resample(wf, sr, SR)
            if wf.size(0) > 1:
                wf = wf.mean(dim=0)
            else:
                wf = wf.squeeze(0)
            audio_segments.append(wf.numpy())
    total_dur = sum(a.shape[0] / SR for a in audio_segments)
    print(f"Loaded {len(audio_segments)} songs ({total_dur:.0f}s total)")
    return audio_segments


def random_crop(audio_pool, num_samples):
    """Random crop from random song."""
    audio = random.choice(audio_pool)
    if len(audio) <= num_samples:
        pad = num_samples - len(audio)
        audio = np.pad(audio, (0, pad), mode='wrap')
    start = random.randint(0, len(audio) - num_samples)
    return audio[start:start + num_samples].copy()


def sample_eq_params():
    """Sample random multi-type EQ parameters for N_BANDS bands."""
    params = []
    for _ in range(N_BANDS):
        ft = random.choices(range(5), weights=TYPE_WEIGHTS, k=1)[0]
        if ft == FILTER_PEAKING:
            g = random.choice([-1, 1]) * random.uniform(1, 18)
            f = math.exp(random.uniform(math.log(50), math.log(18000)))
            q = math.exp(random.uniform(math.log(0.2), math.log(8)))
        elif ft == FILTER_LOWSHELF:
            g = random.choice([-1, 1]) * random.uniform(1, 18)
            f = math.exp(random.uniform(math.log(50), math.log(3000)))
            q = math.exp(random.uniform(math.log(0.2), math.log(5)))
        elif ft == FILTER_HIGHSHELF:
            g = random.choice([-1, 1]) * random.uniform(1, 18)
            f = math.exp(random.uniform(math.log(1500), math.log(18000)))
            q = math.exp(random.uniform(math.log(0.2), math.log(5)))
        elif ft == FILTER_HIGHPASS:
            g = 0.0
            f = math.exp(random.uniform(math.log(30), math.log(400)))
            q = math.exp(random.uniform(math.log(0.2), math.log(1.5)))
        else:  # lowpass
            g = 0.0
            f = math.exp(random.uniform(math.log(3000), math.log(18000)))
            q = math.exp(random.uniform(math.log(0.2), math.log(1.5)))
        params.append({"gain": g, "freq": f, "q": q, "type": ft})
    params.sort(key=lambda p: p["freq"])
    return params


def biquad_coefficients(gain_db, freq, q, ftype, sr=44100):
    """Compute biquad filter coefficients for one band."""
    if ftype in (FILTER_PEAKING, FILTER_LOWSHELF, FILTER_HIGHSHELF):
        A = 10.0 ** (gain_db / 40.0)
    else:
        A = 1.0
    w0 = 2.0 * math.pi * freq / sr
    alpha = math.sin(w0) / (2.0 * q)
    sqA = math.sqrt(A) if A > 0 else 1.0

    if ftype == FILTER_PEAKING:
        b0 = 1 + alpha * A
        b1 = -2 * math.cos(w0)
        b2 = 1 - alpha * A
        a0 = 1 + alpha / A
        a1 = -2 * math.cos(w0)
        a2 = 1 - alpha / A
    elif ftype == FILTER_LOWSHELF:
        b0 = A * ((A + 1) - (A - 1) * math.cos(w0) + 2 * sqA * alpha)
        b1 = 2 * A * ((A - 1) - (A + 1) * math.cos(w0))
        b2 = A * ((A + 1) - (A - 1) * math.cos(w0) - 2 * sqA * alpha)
        a0 = (A + 1) + (A - 1) * math.cos(w0) + 2 * sqA * alpha
        a1 = -2 * ((A - 1) + (A + 1) * math.cos(w0))
        a2 = (A + 1) + (A - 1) * math.cos(w0) - 2 * sqA * alpha
    elif ftype == FILTER_HIGHSHELF:
        b0 = A * ((A + 1) + (A - 1) * math.cos(w0) + 2 * sqA * alpha)
        b1 = -2 * A * ((A - 1) + (A + 1) * math.cos(w0))
        b2 = A * ((A + 1) + (A - 1) * math.cos(w0) - 2 * sqA * alpha)
        a0 = (A + 1) - (A - 1) * math.cos(w0) + 2 * sqA * alpha
        a1 = 2 * ((A - 1) - (A + 1) * math.cos(w0))
        a2 = (A + 1) - (A - 1) * math.cos(w0) - 2 * sqA * alpha
    elif ftype == FILTER_HIGHPASS:
        b0 = (1 + math.cos(w0)) / 2
        b1 = -(1 + math.cos(w0))
        b2 = (1 + math.cos(w0)) / 2
        a0 = 1 + alpha
        a1 = -2 * math.cos(w0)
        a2 = 1 - alpha
    else:  # lowpass
        b0 = (1 - math.cos(w0)) / 2
        b1 = 1 - math.cos(w0)
        b2 = (1 - math.cos(w0)) / 2
        a0 = 1 + alpha
        a1 = -2 * math.cos(w0)
        a2 = 1 - alpha

    return np.array([b0/a0, b1/a0, b2/a0]), np.array([1.0, a1/a0, a2/a0])


def apply_eq_freq_domain(dry_audio, params, sr=44100, n_fft=2048):
    """Apply multi-type EQ cascade in frequency domain."""
    from scipy.signal import lfilter
    wet = dry_audio.copy()
    for p in params:
        b, a = biquad_coefficients(p["gain"], p["freq"], p["q"], p["type"], sr)
        wet = lfilter(b, a, wet)
    return wet


def build_mel_filterbank(n_fft, n_mels, sr):
    """Build mel filterbank matrix."""
    n_freqs = n_fft // 2 + 1
    f_min, f_max = 20.0, sr / 2.0
    hz2mel = lambda h: 2595.0 * np.log10(1 + h / 700.0)
    mel2hz = lambda m: 700.0 * (10.0 ** (m / 2595.0) - 1.0)
    mel_pts = np.linspace(hz2mel(f_min), hz2mel(f_max), n_mels + 2)
    hz_pts = mel2hz(mel_pts)
    bins = ((n_fft + 1) * hz_pts / sr).astype(int)
    fb = np.zeros((n_mels, n_freqs))
    for i in range(n_mels):
        for j in range(bins[i], bins[i+1]):
            if j < n_freqs and bins[i+1] > bins[i]:
                fb[i, j] = (j - bins[i]) / (bins[i+1] - bins[i])
        for j in range(bins[i+1], bins[i+2]):
            if j < n_freqs and bins[i+2] > bins[i+1]:
                fb[i, j] = (bins[i+2] - j) / (bins[i+2] - bins[i+1])
    return torch.tensor(fb, dtype=torch.float32)


def audio_to_mel(audio_np, mel_fb):
    """Convert audio numpy array to log-mel spectrogram tensor."""
    audio_t = torch.from_numpy(audio_np).float()
    window = torch.hann_window(N_FFT)
    stft = torch.stft(audio_t.unsqueeze(0), N_FFT, HOP, N_FFT,
                       window=window, return_complex=True)
    mag = torch.abs(stft).squeeze(0)
    mel = mel_fb @ mag
    mel = torch.clamp(mel, min=1e-8)
    return torch.log(mel)


def main():
    print(f"Generating {SIZE:,} MUSDB18 EQ samples")
    print(f"  SR={SR}, N_FFT={N_FFT}, HOP={HOP}, N_MELS={N_MELS}, DURATION={DURATION}s")
    print(f"  N_BANDS={N_BANDS}, BATCH_SAVE={BATCH_SAVE:,}")

    audio_pool = load_musdb_audio()
    mel_fb = build_mel_filterbank(N_FFT, N_MELS, SR)

    output_path = Path("data/dataset_musdb_200k.pt")
    output_path.parent.mkdir(exist_ok=True)

    all_cache = []
    t0 = time.time()

    for i in range(SIZE):
        # Random crop
        dry = random_crop(audio_pool, NUM_SAMPLES)

        # Random EQ parameters
        params = sample_eq_params()

        # Apply EQ
        wet = apply_eq_freq_domain(dry, params, SR, N_FFT)

        # Loudness augmentation
        scale = random.uniform(0.5, 1.0)
        wet = wet * scale

        # Convert to mel
        wet_mel = audio_to_mel(wet, mel_fb)

        # Store as tensors
        gain = torch.tensor([p["gain"] for p in params], dtype=torch.float32)
        freq = torch.tensor([p["freq"] for p in params], dtype=torch.float32)
        q = torch.tensor([p["q"] for p in params], dtype=torch.float32)
        ftype = torch.tensor([p["type"] for p in params], dtype=torch.long)

        all_cache.append({
            "wet_mel": wet_mel,
            "gain": gain,
            "freq": freq,
            "q": q,
            "filter_type": ftype,
        })

        # Progress reporting
        if (i + 1) % 5000 == 0:
            elapsed = time.time() - t0
            rate = (i + 1) / elapsed
            eta = (SIZE - i - 1) / rate
            print(f"  {i+1:>8,}/{SIZE:,} ({rate:.0f} samples/s, ETA {eta:.0f}s)")

        # Save in batches to manage memory
        if (i + 1) % BATCH_SAVE == 0:
            batch_path = output_path.parent / f"dataset_musdb_200k_batch_{(i+1)//BATCH_SAVE}.pt"
            torch.save(all_cache, str(batch_path))
            print(f"  Saved batch to {batch_path} ({len(all_cache)} samples)")
            all_cache = []

    # Save any remaining samples
    if all_cache:
        batch_num = (SIZE // BATCH_SAVE) + 1
        batch_path = output_path.parent / f"dataset_musdb_200k_batch_{batch_num}.pt"
        torch.save(all_cache, str(batch_path))
        print(f"  Saved final batch to {batch_path} ({len(all_cache)} samples)")

    # Merge all batch files into single dataset
    print("\nMerging batch files...")
    full_cache = []
    batch_files = sorted(output_path.parent.glob("dataset_musdb_200k_batch_*.pt"))
    for bf in batch_files:
        batch = torch.load(str(bf), weights_only=False)
        full_cache.extend(batch)
        print(f"  Loaded {len(batch)} from {bf.name}")
        # Remove batch file after merging
        bf.unlink()

    torch.save(full_cache, str(output_path))
    elapsed = time.time() - t0
    print(f"\nDone! Saved {len(full_cache):,} samples to {output_path}")
    print(f"  Total time: {elapsed:.0f}s ({elapsed/60:.1f}min)")
    print(f"  File size: {output_path.stat().st_size / 1e9:.1f} GB")


if __name__ == "__main__":
    random.seed(42)
    np.random.seed(42)
    torch.manual_seed(42)
    main()
