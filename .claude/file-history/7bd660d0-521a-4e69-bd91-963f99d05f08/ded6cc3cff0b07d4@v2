## Production Configuration

```yaml
# Recommended production configuration
model:
  encoder:
    channels: 128
    num_blocks: 4
    num_stacks: 2
    kernel_size: 3
    embedding_dim: 128
  param_head:
    num_bands: 3
    attn_temperature: 0.1
    gumbel_temperature: 0.05

data:
  sample_rate: 44100
  audio_duration: 1.5
  n_fft: 2048
  hop_length: 256
  n_mels: 256  # Consider 512 for narrow-Q work
  dataset_size: 50000
  batch_size: auto

training:
  learning_rate: 0.0001
  weight_decay: 0.0001
  precision: bf16-mixed
  accumulate_grad_batches: 2
  early_stopping_patience: 20

loss_weights:
  lambda_param: 1.0
  lambda_type: 2.0
  lambda_hmag: 2.0
  lambda_spectral: 1.0
  lambda_activity: 0.1
  lambda_spread: 0.05
  lambda_coverage: 0.3
  lambda_freq_anchor: 5.0
  lambda_attn_entropy: 0.05

curriculum:
  stages:
    - name: easy_peaking
      filter_types: [peaking]
      min_gain_db: 6.0
      gumbel_temperature: 1.0
      epochs: 20
    - name: medium_peaking
      filter_types: [peaking]
      min_gain_db: 3.0
      gumbel_temperature: 0.5
      epochs: 20
    - name: frequency_spread
      lambda_spread: 0.2
      lambda_coverage: 0.3
      gumbel_temperature: 0.3
      epochs: 15
    - name: full_multitype
      filter_types: [peaking, lowshelf, highshelf, highpass, lowpass]
      gumbel_temperature: 0.05
      epochs: 30
    - name: full_difficulty
      min_gain_db: 0.0
      gumbel_temperature: 0.05
      epochs: 30
```

