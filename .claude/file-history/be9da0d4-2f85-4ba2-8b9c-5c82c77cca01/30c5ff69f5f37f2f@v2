"""Plot training curves from training_history.json."""
import json
import sys
from pathlib import Path

import matplotlib
matplotlib.use("Agg")
import matplotlib.pyplot as plt
import numpy as np

hist_path = Path("checkpoints/training_history.json")
if not hist_path.exists():
    print(f"No history at {hist_path}")
    sys.exit(1)

with open(hist_path) as f:
    history = json.load(f)

epochs = [h["epoch"] for h in history]
train_loss = [h["train_loss"] for h in history]
val_loss = [h["val_loss"] for h in history]
gain_mae = [h["metrics"].get("gain", 0) for h in history]
freq_mae = [h["metrics"].get("freq", 0) for h in history]
q_mae = [h["metrics"].get("q", 0) for h in history]
type_acc = [h["metrics"].get("type_acc", 0) * 100 for h in history]

fig, axes = plt.subplots(2, 3, figsize=(18, 10))
fig.suptitle("IDSP EQ Estimator - 50K MUSDB18 Training", fontsize=14, fontweight="bold")

# Stage boundaries
stage_boundaries = [10, 30]  # warmup→type_learning, type_learning→consolidation
for ax in axes.flat:
    for b in stage_boundaries:
        if b < max(epochs):
            ax.axvline(x=b, color="gray", linestyle="--", alpha=0.4, linewidth=0.8)

# Loss
ax = axes[0, 0]
ax.plot(epochs, train_loss, "b-", label="Train", linewidth=1.5)
ax.plot(epochs, val_loss, "r-", label="Val", linewidth=1.5)
ax.set_xlabel("Epoch")
ax.set_ylabel("Loss")
ax.set_title("Total Loss")
ax.legend()
ax.grid(True, alpha=0.3)

# Gain MAE
ax = axes[0, 1]
ax.plot(epochs, gain_mae, "g-", linewidth=1.5)
ax.set_xlabel("Epoch")
ax.set_ylabel("MAE (dB)")
ax.set_title("Gain MAE (Hungarian-matched)")
ax.grid(True, alpha=0.3)

# Freq MAE
ax = axes[0, 2]
ax.plot(epochs, freq_mae, "m-", linewidth=1.5)
ax.set_xlabel("Epoch")
ax.set_ylabel("MAE (octaves)")
ax.set_title("Frequency MAE")
ax.grid(True, alpha=0.3)

# Q MAE
ax = axes[1, 0]
ax.plot(epochs, q_mae, "c-", linewidth=1.5)
ax.set_xlabel("Epoch")
ax.set_ylabel("MAE (decades)")
ax.set_title("Q MAE")
ax.grid(True, alpha=0.3)

# Type accuracy
ax = axes[1, 1]
ax.plot(epochs, type_acc, "orange", linewidth=1.5)
ax.axhline(y=20, color="red", linestyle=":", alpha=0.5, label="Random (20%)")
ax.set_xlabel("Epoch")
ax.set_ylabel("Accuracy (%)")
ax.set_title("Filter Type Accuracy")
ax.legend()
ax.grid(True, alpha=0.3)

# Time per epoch
ax = axes[1, 2]
times = [h["time_s"] for h in history]
ax.plot(epochs, times, "k-", linewidth=1.5)
ax.set_xlabel("Epoch")
ax.set_ylabel("Time (s)")
ax.set_title("Epoch Duration")
ax.grid(True, alpha=0.3)

# Add stage labels
for ax in axes.flat:
    ax.text(0.02, 0.95, "warmup", transform=ax.transAxes, fontsize=7, alpha=0.5, va="top")
    if max(epochs) > 10:
        ax.text(0.35, 0.95, "type_learn", transform=ax.transAxes, fontsize=7, alpha=0.5, va="top")
    if max(epochs) > 30:
        ax.text(0.7, 0.95, "consolidate", transform=ax.transAxes, fontsize=7, alpha=0.5, va="top")

plt.tight_layout()
out_path = "checkpoints/training_curves_musdb_50k.png"
plt.savefig(out_path, dpi=150, bbox_inches="tight")
print(f"Saved training curves to {out_path}")

# Print summary
print(f"\nFinal Results (best epoch):")
print(f"  Best val loss: {min(val_loss):.4f} at epoch {epochs[val_loss.index(min(val_loss))]}")
print(f"  Gain MAE: {min(gain_mae):.2f} dB")
print(f"  Freq MAE: {min(freq_mae):.3f} octaves")
print(f"  Q MAE: {min(q_mae):.3f} decades")
print(f"  Type Acc: {max(type_acc):.1f}%")
print(f"  Total epochs: {len(epochs)} (early stopped at {max(epochs)})")
