experiment_name: idsp-eq-multitype-blind-estimator
seed: 42
data:
  num_bands: 3
  sample_rate: 44100
  audio_duration: 3.0
  n_fft: 2048
  hop_length: 256
  n_mels: 256
  gain_bounds:
  - -24.0
  - 24.0
  freq_bounds:
  - 20.0
  - 20000.0
  q_bounds:
  - 0.1
  - 10.0
  filter_types:
  - peaking
  type_weights:
  - 1.0
  train_split: 0.8
  val_split: 0.1
  test_split: 0.1
  batch_size: 1024
  num_workers: 44
  dataset_size: 20000
model:
  encoder:
    type: tcn
    n_mels: 256
    embedding_dim: 128
    channels: 128
    num_blocks: 4
    num_stacks: 2
    kernel_size: 5               # Wider kernel for larger receptive field per block
  num_bands: 3
  learning_rate: 0.0001
  weight_decay: 1.0e-05

  # Input representation: false = mel-spectrogram, true = full-band magnitude spectrum
  # Full spectrum preserves fine frequency detail (n_fft//2+1 = 1025 bins vs 256 mel bins)
  # at the cost of ~4x larger input. Recommended for precise frequency estimation.
  use_full_spectrum: false
loss:
  lambda_param: 1.0
  lambda_type: 2.0
  lambda_spectral: 1.0
  lambda_hmag: 2.0
  lambda_activity: 0.1
  lambda_spread: 0.05
  lambda_coverage: 0.3
  lambda_freq_anchor: 2.0
  lambda_attn_entropy: 0.05
  lambda_freq_match: 1.0
  lambda_q_match: 0.5
trainer:
  max_epochs: 30
  accelerator: auto
  devices: 1
  precision: 16-mixed
  log_every_n_steps: 10
  fast_dev_run: false
curriculum:
  stages:
  - name: easy_multitype
    epochs: 15
    filter_types:
    - peaking
    param_ranges:
      gain:
      - -12.0
      - 12.0
      q:
      - 0.3
      - 5.0
    min_gain_db: 6.0
    lambda_type: 3.0
    lambda_freq_anchor: 2.0
    gumbel_temperature: 1.0
  - name: medium_multitype
    epochs: 25
    filter_types:
    - peaking
    param_ranges:
      gain:
      - -18.0
      - 18.0
      q:
      - 0.2
      - 8.0
    min_gain_db: 3.0
    lambda_type: 2.0
    lambda_freq_anchor: 2.0
    gumbel_temperature: 0.5
  - name: frequency_spread
    epochs: 10
    filter_types:
    - peaking
    param_ranges:
      gain:
      - -18.0
      - 18.0
      q:
      - 0.2
      - 8.0
    min_gain_db: 1.0
    lambda_type: 2.0
    lambda_spread: 0.2
    lambda_coverage: 0.3
    lambda_freq_anchor: 1.0
    gumbel_temperature: 0.3
  - name: full_difficulty
    epochs: 30
    filter_types:
    - peaking
    param_ranges:
      gain:
      - -24.0
      - 24.0
      q:
      - 0.1
      - 10.0
    lambda_type: 2.0
    lambda_freq_anchor: 1.0
    gumbel_temperature: 0.1
  - name: realworld_finetune
    epochs: 10
    filter_types:
    - peaking
    param_ranges:
      gain:
      - -24.0
      - 24.0
      q:
      - 0.1
      - 10.0
    lambda_type: 2.0
    lambda_freq_anchor: 1.0
    gumbel_temperature: 0.1
    learning_rate_scale: 0.1
