import torch, sys
sys.path.insert(0, '.')
from model_tcn import StreamingTCNModel
from dsp_frontend import STFTFrontend
from dataset import SyntheticEQDataset
from torch.utils.data import DataLoader
import numpy as np

torch.manual_seed(42)
device = 'cuda' if torch.cuda.is_available() else 'cpu'
print(f'Device: {device}')
model = StreamingTCNModel(n_mels=128, embedding_dim=128, num_bands=5).to(device)
ckpt = 'checkpoints/epoch_002.pt'
sd = torch.load(ckpt, map_location=device, weights_only=False)
model.load_state_dict(sd['model_state_dict'])
model.eval()
print(f'Loaded {ckpt}')

frontend = STFTFrontend(n_fft=2048, hop_length=256, mel_bins=128, sample_rate=44100)
dataset = SyntheticEQDataset(num_samples=100, n_fft=2048, sample_rate=44100)
loader = DataLoader(dataset, batch_size=4, shuffle=False)
batch = next(iter(loader))
 break

with torch.no_grad():
    wet = batch["wet_audio"].to(device)
    tg = batch["gain"].to(device)
    tf = batch["freq"].to(device)
    tq = batch["q"].to(device)
    mel = frontend.mel_spectrogram(wet)
    mel_frames = mel.squeeze(1)
    output = model(mel_frames)
    pg, pf, pq = output["params"]
    print(f"Pred gain: [{pg.min():.5f}, {pg.max():.5f}]")
    print(f"Target gain: [{tg.min():.5f}, {tg.max():.5f}]")
    print(f"Gain MAE/batch: {(pg - tg).abs().mean(1).tolist()}")
    print(f"Gain bias: {(pg.mean(1) - tg.mean(1)).mean():.5f}")
    print(f"Pred freq: [{pf.min():.1f}, {pf.max():.1f}]")
    print(f"Target freq: [{tf.min():.1f}, {tf.max():.1f}]")
    # mel residual analysis
    mel_prof = mel_frames.mean(dim=-1)
    ms = model.param_head.gain_smooth_pool(mel_prof.unsqueeze(1)).squeeze(1)
    mr = mel_prof - ms
    print(f"Mel residual range: [{mr.min():.5f}, {mr.max():.5f}]")
    print(f"Mel residual std: {mr.std():.5f}')
    print(f"Gain cal_scale: {model.param_head.gain_cal_scale.data.tolist()}")
    print(f"Gain cal_bias: {model.param_head.gain_cal_bias.data.tolist()}}')
